# fresh runs always have stable UUIDs and don't regenerate specs from scratch)
pipeline-state/*
!pipeline-state/regression-baseline.json

# ── Playwright ────────────────────────────────────────────────
playwright-report/
/test-results/
playwright-agt06-run-*.config.js

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────
.vscode/*
.idea/
*.swp
*.swo

*.pptx
/infra
scripts/build-exec-pptx.py

# ── Wiki drafts (maintained directly on GitHub Wiki) ──────────
docs/wiki/
