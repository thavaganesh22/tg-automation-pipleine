# ── Environment & Secrets ─────────────────────────────────────
.env
.env.local
.env.*.local
.env.azure

# ── Build Outputs ─────────────────────────────────────────────
dist/
build/

# ── Node ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Generated by Pipeline Agents ──────────────────────────────
test-results/
reports/
