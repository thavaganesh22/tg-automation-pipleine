# ──────────────────────────────────────────────────────────────
# .env.example  —  Copy to .env and fill in your values
# NEVER commit .env to version control
# ──────────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── JIRA ──────────────────────────────────────────────────────
JIRA_TOKEN=your-jira-api-token
JIRA_HOST=https://yourcompany.atlassian.net
JIRA_HOST_ALLOWLIST=https://yourcompany.atlassian.net
JIRA_PROJECT_KEY=PROJ
# JIRA_SPRINT_ID is no longer used — AGT-02 fetches the specific story
# identified in the PR (TGDEMO-xxxxx) directly, not via sprint JQL.
# JIRA_SPRINT_ID=

# ── Repository Target ─────────────────────────────────────────
REPO_PATH=./                           # Path to the codebase to analyse
OPEN_API_PATH=./api-specs/openapi.json # Optional: OpenAPI spec for fixture generation

# ── PR Context (set automatically by GitHub Actions on pull_request events) ─
# These are injected by the CI workflow — only set manually for local testing.
PR_TITLE="feat: TGDEMO-12345 add payment gateway integration"
PR_BRANCH="feat/TGDEMO-12345-payment-gateway"
PR_NUMBER="42"
GITHUB_BASE_REF="main"
# PR_CHANGED_FILES is a newline-separated list of files changed in the PR.
# Set automatically by the 'Resolve changed files' CI step.
# PR_CHANGED_FILES=src/payments/gateway.ts\nsrc/payments/gateway.test.ts

# ── Test Execution ────────────────────────────────────────────
# GUARDRAIL: staging/sandbox only — never point at production
ALLOWED_TEST_URLS=https://staging.yourapp.com,https://preview.yourapp.com
BASE_URL=https://staging.yourapp.com

# ── Database (time-series run history) ────────────────────────
DATABASE_URL=postgresql://qa_user:password@localhost:5432/qa_reports

# ── SLA & Alerts ──────────────────────────────────────────────
SLA_PASS_RATE=0.95                     # Alert if pass rate drops below 95%
STAKEHOLDER_EMAILS=qa@company.com,eng-lead@company.com

# ── Guardrail Thresholds ──────────────────────────────────────
MIN_P0_COVERAGE=80                     # Block execution if P0 Playwright coverage < 80%
MIN_P1_COVERAGE=80                     # Block execution if P1 Playwright coverage < 80%
MAX_GAP_PERCENT=20                     # Escalate to human reviewer if gap > 20%
MAX_FILES_SCAN=1000                    # Max files AGT-01 will scan per run
MAX_TEST_CASES=500                     # Max test cases AGT-03 will generate per cycle

# ── Email (AGT-07 stakeholder reports) ────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=your-smtp-password
