{
  "name": "qa-pipeline",
  "version": "1.0.0",
  "description": "7-Agent Autonomous QA Testing Pipeline powered by Claude",
  "main": "dist/orchestrator/index.js",
  "scripts": {
    "build": "tsc",
    "pipeline": "ts-node orchestrator/index.ts",
    "pipeline:from": "ts-node orchestrator/index.ts --from=",
    "pipeline:agent": "ts-node orchestrator/index.ts --agent=",
    "test:specs": "playwright test playwright-tests/specs",
    "test:unit": "jest",
    "db:migrate": "ts-node db/migrate.ts",
    "db:seed": "ts-node db/seed.ts",
    "report:serve": "ts-node scripts/serve-dashboard.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@playwright/test": "^1.44.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "fast-glob": "^3.3.2",
    "nodemailer": "^6.9.0",
    "pg": "^8.11.0",
    "prettier": "^3.2.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
