# =============================================================================
# .env.azure.example
# Copy to .env.azure (gitignored) and fill in real values for local runs
# that target the always-on Azure Elastic stack.
#
#   cp .env.azure.example .env.azure
#   source .env.azure && npm run pipeline
#
# To target local Elasticsearch instead:
#   ELASTICSEARCH_URL=http://localhost:9200 npm run pipeline
# =============================================================================

# Full Elasticsearch URL including credentials.
# Format: http://elastic:<password>@<vm-fqdn>:9200
# VM FQDN pattern: <dns-label>.<location>.cloudapp.azure.com
# Default VM provisioned by infra/azure/vm-setup.sh:
ELASTICSEARCH_URL=http://elastic:cbtsreport2$@cbts-elastic-vm.eastus.cloudapp.azure.com:9200

# Admin alert targets (used by infra/azure/notify-elastic-down.js).
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...
ADMIN_EMAIL=admin@yourcompany.com

# SMTP — only needed if testing the email alert locally.
SMTP_HOST=smtp.yourprovider.com
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=CHANGE_ME

# Azure VM / CLI config — only needed if running infra scripts locally.
AZ_RESOURCE_GROUP=RG-CBTS-App-Dev-Demo-Lab
AZ_ELASTIC_HOST=cbts-elastic-vm.eastus.cloudapp.azure.com
